# replace `<x>` placeholders with actual values and rename to `.env` to use

# example of configuring Ignis application via environment variables.
# 06-06-seo - how to enable SEO module

NUXT_PUBLIC_IGNIS_CONTENT_SEO_ENABLED=true

# test https://github.com/AloisSeckar/nuxt-ignis/issues/170
NUXT_PUBLIC_IGNIS_CONTENT_SEO_STATICSITE=true

# test special handling for `ssr: false` in SEO module
NUXT_PUBLIC_IGNIS_CONFIG_NUXT_SSR=false
