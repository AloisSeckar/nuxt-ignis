# replace `<x>` placeholders with actual values and rename to `.env` to use

# example of configuring Ignis application via environment variables.
# 02-02-tailwind - how to use Tailwind CSS as the UI preset
# + using "css" option for custom CSS files

NUXT_PUBLIC_IGNIS_PRESET_UI=tailwind

NUXT_PUBLIC_IGNIS_CONFIG_NUXT_CSS=~/assets/custom.css
