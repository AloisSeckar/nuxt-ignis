# replace `<x>` placeholders with actual values and rename to `.env` to use

# example of configuring Ignis application via environment variables.
# 07-01-equipment - how to enable Equipment plugins (MagicNoise, MagicMarquee)

NUXT_PUBLIC_IGNIS_UI_PRESET=tailwind
NUXT_PUBLIC_IGNIS_EQUIPMENT_ENABLED=true
NUXT_PUBLIC_IGNIS_EQUIPMENT_PLUGINS=MagicNoise, MagicMarquee
