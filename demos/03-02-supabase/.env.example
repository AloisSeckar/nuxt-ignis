# replace `<x>` placeholders with actual values and rename to `.env` to use

# example of configuring Ignis application via environment variables.
# 03-02-supabase - how to use Supabase as the database preset

NUXT_PUBLIC_IGNIS_PRESET_DB=supabase

SUPABASE_URL=<Supabase_url>
SUPABASE_KEY=<Supabase_app_key>
