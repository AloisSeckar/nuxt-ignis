# 06-04-i18n - how to enable internationalization (i18n)

NUXT_PUBLIC_IGNIS_CONTENT_I18N_ENABLED=true

# to set different default locale than 'en'
#NUXT_PUBLIC_IGNIS_CONTENT_I18N_DEFAULT=es
