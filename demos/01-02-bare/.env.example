# replace `<x>` placeholders with actual values and rename to `.env` to use

# example of configuring Ignis application via environment variables.
# 01-02-bare - how to disable all default Nuxt Ignis core features (minimal setup)

NUXT_PUBLIC_IGNIS_CORE_ESLINT=false
NUXT_PUBLIC_IGNIS_CORE_FONTS=false
NUXT_PUBLIC_IGNIS_CORE_IMAGE=false
NUXT_PUBLIC_IGNIS_CORE_SCRIPTS=false
NUXT_PUBLIC_IGNIS_CORE_SECURITY=false
NUXT_PUBLIC_IGNIS_CORE_AUTH=false
NUXT_PUBLIC_IGNIS_CORE_VUEUSE=false
NUXT_PUBLIC_IGNIS_CORE_PINIA=false
NUXT_PUBLIC_IGNIS_CORE_CSS=false
