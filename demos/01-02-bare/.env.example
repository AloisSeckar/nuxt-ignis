# replace `<x>` placeholders with actual values and rename to `.env` to use

# example of configuring Ignis application via environment variables.
# 01-02-bare - how to disable all default Nuxt Ignis default features (minimal setup)

NUXT_PUBLIC_IGNIS_DEFAULT_ESLINT=false
NUXT_PUBLIC_IGNIS_DEFAULT_FONTS=false
NUXT_PUBLIC_IGNIS_DEFAULT_IMAGE=false
NUXT_PUBLIC_IGNIS_DEFAULT_SCRIPTS=false
NUXT_PUBLIC_IGNIS_DEFAULT_SECURITY=false
NUXT_PUBLIC_IGNIS_DEFAULT_AUTH=false
NUXT_PUBLIC_IGNIS_DEFAULT_VUEUSE=false
NUXT_PUBLIC_IGNIS_DEFAULT_PINIA=false
NUXT_PUBLIC_IGNIS_DEFAULT_CSS=false
