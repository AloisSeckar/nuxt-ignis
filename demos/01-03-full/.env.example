# replace `<x>` placeholders with actual values and rename to `.env` to use

# example of configuring Ignis application via environment variables.
# 01-03-full - how to enable all available Nuxt Ignis features

# config
NUXT_PUBLIC_IGNIS_CONFIG_WARN_DUPLICATES=false

# default features
NUXT_PUBLIC_IGNIS_DEFAULT_AUTH=true
NUXT_PUBLIC_IGNIS_DEFAULT_CSS=true
NUXT_PUBLIC_IGNIS_DEFAULT_ESLINT=true
NUXT_PUBLIC_IGNIS_DEFAULT_FONTS=true
NUXT_PUBLIC_IGNIS_DEFAULT_IMAGE=true
NUXT_PUBLIC_IGNIS_DEFAULT_PINIA=true
NUXT_PUBLIC_IGNIS_DEFAULT_SCRIPTS=true
NUXT_PUBLIC_IGNIS_DEFAULT_SECURITY=true
NUXT_PUBLIC_IGNIS_DEFAULT_VUEUSE=true

# ui
NUXT_PUBLIC_IGNIS_UI_UI=false
NUXT_PUBLIC_IGNIS_UI_TAILWIND=false
NUXT_PUBLIC_IGNIS_UI_OPENPROPS=false
NUXT_PUBLIC_IGNIS_UI_CHARTS=false

# db
NUXT_PUBLIC_IGNIS_DB_NEON_ENABLED=true
NUXT_PUBLIC_IGNIS_DB_SUPABASE_ENABLED=true

# forms
NUXT_PUBLIC_IGNIS_FORMS_FORMKIT_ENABLED=true
NUXT_PUBLIC_IGNIS_FORMS_FORMKIT_DEFAULT=en
NUXT_PUBLIC_IGNIS_FORMS_VUEFORM_ENABLED=true

# validation
NUXT_PUBLIC_IGNIS_VALIDATION_VALIBOT=true
NUXT_PUBLIC_IGNIS_VALIDATION_ZOD=true

# content
NUXT_PUBLIC_IGNIS_CONTENT_CONTENT_ENABLED=true
NUXT_PUBLIC_IGNIS_CONTENT_I18N_ENABLED=true
NUXT_PUBLIC_IGNIS_CONTENT_I18N_DEFAULT=en
NUXT_PUBLIC_IGNIS_CONTENT_SEO_ENABLED=true
NUXT_PUBLIC_IGNIS_CONTENT_SOCIAL_ENABLED=true
NUXT_PUBLIC_IGNIS_CONTENT_SOCIAL_URL=https://nuxt-ignis.com
NUXT_PUBLIC_IGNIS_CONTENT_PSLO_ENABLED=true
NUXT_PUBLIC_IGNIS_CONTENT_PSLO_CONTENT=true

# ui
NUXT_PUBLIC_IGNIS_UI_TAILWIND=true
NUXT_PUBLIC_IGNIS_UI_UI=true
NUXT_PUBLIC_IGNIS_UI_CHARTS=true
NUXT_PUBLIC_IGNIS_UI_OPENPROPS=true

# utils
NUXT_PUBLIC_IGNIS_UTILS_EQUIPMENT_ENABLED=true
NUXT_PUBLIC_IGNIS_UTILS_REGEXP_ENABLED=true

# external services (replace with actual values)
NUXT_NEON_HOST=<NeonDB_host>
NUXT_NEON_USER=<NeonDB_user>
NUXT_NEON_PASS=<NeonDB_pass>
NUXT_PUBLIC_NEON_DB=<NeonDB_name>

SUPABASE_URL=<Supabase_url>
SUPABASE_KEY=<Supabase_app_key>
